{
    "name": "template-react-ts",
    "description": "A Phaser 3 TypeScript project template that demonstrates React communication and uses Vite for bundling.",
    "version": "1.1.0",
    "author": "Mokk Studio extended Phaser Studio (https://phaser.io/)",
    "license": "MIT",
    "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
    "keywords": [
        "phaser",
        "phaser3",
        "react",
        "vite",
        "typescript"
    ],
    "scripts": {
        "dev": "node log.js dev & vite --config vite/config.dev.mjs",
        "build": "node log.js build & tsc && vite build --config vite/config.prod.mjs",
        "preview": "vite preview --port 8080",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "dev-nolog": "vite --config vite/config.dev.mjs",
        "build-nolog": "vite build --config vite/config.prod.mjs"
    },
    "dependencies": {
        "@capacitor-community/electron": "^5.0.1",
        "@capacitor/app": "^8.1.0",
        "@capacitor/core": "^8.3.0",
        "@capacitor/haptics": "^8.0.2",
        "@capacitor/status-bar": "^8.0.2",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.7.0",
        "phaser": "^3.90.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@capacitor/android": "^8.3.0",
        "@capacitor/cli": "^8.3.0",
        "@capacitor/ios": "^8.3.0",
        "@eslint/js": "^9.22.0",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^16.0.0",
        "tailwindcss": "^4.2.2",
        "terser": "^5.28.1",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.26.1",
        "vite": "^6.3.1"
    }
}